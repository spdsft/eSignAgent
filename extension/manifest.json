{
  "manifest_version": 3,
  "name": "eSignAgent",
  "short_name": "eSignAgent",
  "version": "1.0.1",
  "description": "Open-source PDF digital signing client for web applications.",
  "_comment_key": "Locks the extension ID to aoonbefkefmhoicoceilifnngkenmfah regardless of install mode (Load unpacked vs .crx). Derived from the project's signing .pem.",
  "key": "",

  "icons": {
    "16":  "icons/icon-16.png",
    "32":  "icons/icon-32.png",
    "48":  "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },

  "background": {
    "service_worker": "background.js"
  },

  "_comment_matches": "Default matches cover localhost development. Forks should add their own production domains under content_scripts.matches and host_permissions, then rebuild the .crx.",
  "content_scripts": [
    {
      "matches": [
        "http://localhost/*",
        "https://localhost/*",
        "http://127.0.0.1/*",
        "https://127.0.0.1/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start",
      "world": "ISOLATED"
    },
    {
      "matches": [
        "http://localhost/*",
        "https://localhost/*",
        "http://127.0.0.1/*",
        "https://127.0.0.1/*"
      ],
      "js": ["page-bridge.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],

  "permissions": [
    "nativeMessaging"
  ],

  "host_permissions": [
    "http://localhost/*",
    "https://localhost/*",
    "http://127.0.0.1/*",
    "https://127.0.0.1/*"
  ]
}
